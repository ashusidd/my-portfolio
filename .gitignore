# --- Dependencies ---
# This ignores the heavy folders in both your React and Node folders
client/node_modules/
server/node_modules/

# --- Environment Secrets ---
# VERY IMPORTANT: This prevents your MongoDB password from going to GitHub
server/.env
.env
.env.local
.env.*.local

# --- Build Outputs ---
# Ignores the production files generated by Vite/React
client/dist/
client/dist-ssr/
server/dist/

# --- Logs ---
# Ignores error logs that clutter your repository
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# --- Editor & System Files ---
# Ignores files created by VS Code or your Operating System
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.sw?
